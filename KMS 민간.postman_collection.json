  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "console.log(\"collection pre-request scripts 시작\")",
          "",
          "const accessKey = pm.environment.get('ACCESS_KEY');",
          "const secretKey = pm.environment.get('SECRET_KEY');",
          "const TIMESTAMP = new Date().getTime().toString();",
          "pm.variables.set(\"TIMESTAMP\", TIMESTAMP);",
          "",
          "const utils = eval(pm.globals.get('loadUtils'));",
          "const hash = utils.makeSignature(secretKey, accessKey,TIMESTAMP);",
          "pm.variables.set('HASH', hash);",
          "",
          "// set header",
          "pm.request.headers.add({ key: \"x-ncp-iam-access-key\", value: pm.environment.get('ACCESS_KEY')})",
          "pm.request.headers.add({ key: \"x-ncp-apigw-timestamp\", value: pm.variables.get('TIMESTAMP')})",
          "pm.request.headers.add({ key: \"x-ncp-apigw-signature-v2\", value: pm.variables.get('HASH')})",
          "",
          "",
          "console.log(\"collection pre-request scripts종료\")"
        ]
      }
    },
